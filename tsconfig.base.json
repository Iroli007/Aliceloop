{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@aliceloop/pdf-ingest": [
        "packages/pdf-ingest/src/index.ts"
      ],
      "@aliceloop/runtime-core": [
        "packages/runtime-core/src/index.ts"
      ]
    },
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  }
}
