{
  "name": "@aliceloop/daemon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./server": {
      "import": "./dist/server.js"
    }
  },
  "bin": {
    "aliceloop": "./dist/cli/index.js"
  },
  "description": "Local runtime daemon for Aliceloop.",
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts src/server.ts --dts --format esm --out-dir dist --external ws --external bufferutil --external utf-8-validate --external better-sqlite3 --external bindings",
    "dev": "ALICELOOP_DAEMON_PORT=3031 ALICELOOP_CHROME_RELAY_PORT=23101 tsx src/index.ts",
    "smoke:all": "npm run smoke:queue && npm run smoke:sandbox && npm run smoke:skills && npm run smoke:cli && npm run smoke:tasks && npm run smoke:tasks:api && npm run smoke:memory",
    "smoke:cli": "tsx scripts/cliSmoke.ts",
    "smoke:desktop-relay": "tsx scripts/desktopChromeRelaySmoke.ts",
    "bench:load-context": "tsx scripts/loadContextBenchmark.ts",
    "bench:desktop-relay": "tsx scripts/desktopChromeRelayBenchmark.ts",
    "smoke:memory": "tsx scripts/memorySystemSmoke.ts",
    "smoke:memory-skills": "tsx scripts/memoryThreadSkillsSmoke.ts",
    "smoke:queue": "tsx scripts/sessionRunQueueSmoke.ts",
    "smoke:sandbox": "tsx scripts/sandboxSmoke.ts",
    "smoke:skills": "tsx scripts/skillToolsSmoke.ts",
    "smoke:tasks:api": "tsx scripts/taskApiSmoke.ts",
    "smoke:tasks": "tsx scripts/taskRunsSmoke.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@aliceloop/pdf-ingest": "file:../../packages/pdf-ingest",
    "@aliceloop/runtime-core": "file:../../packages/runtime-core",
    "@fastify/cors": "^11.1.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.4.0",
    "tsx": "^4.20.3",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
