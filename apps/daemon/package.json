{
  "name": "@aliceloop/daemon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Local runtime daemon for Aliceloop.",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --out-dir dist",
    "dev": "tsx watch src/index.ts",
    "smoke:queue": "tsx scripts/sessionRunQueueSmoke.ts",
    "smoke:sandbox": "tsx scripts/sandboxSmoke.ts",
    "smoke:tasks:api": "tsx scripts/taskApiSmoke.ts",
    "smoke:tasks": "tsx scripts/taskRunsSmoke.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@aliceloop/pdf-ingest": "file:../../packages/pdf-ingest",
    "@aliceloop/runtime-core": "file:../../packages/runtime-core",
    "@fastify/cors": "^11.1.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
