{
  "name": "@aliceloop/desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/main/index.js",
  "author": "Aliceloop",
  "description": "Electron desktop shell for Aliceloop.",
  "scripts": {
    "build": "electron-vite build",
    "build:web": "vite build --config vite.renderer.config.ts",
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.renderer.config.ts",
    "package:extension": "node ./scripts/exportChromeRelayExtension.mjs",
    "package:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir && npm run package:extension",
    "package:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir && npm run package:extension",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aliceloop/runtime-core": "file:../../packages/runtime-core",
    "bufferutil": "^4.1.0",
    "playwright-core": "^1.58.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.aliceloop.desktop",
    "productName": "Aliceloop",
    "electronVersion": "37.10.3",
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../chrome-extension",
        "to": "chrome-extension"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "identity": null
    },
    "win": {
      "icon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Development"
    }
  }
}
