    "build": "tsup src/index.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aliceloop/runtime-core": "file:../runtime-core"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
