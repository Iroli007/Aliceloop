{
  "name": "@aliceloop/pdf-ingest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "PDF structure extraction, navigation, and ingest pipeline.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
